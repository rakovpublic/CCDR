<td class="formula"><math id="M50" display="block"><msub><mrow><mi>P</mi></mrow><mrow><mi mathvariant="bold-italic">q</mi></mrow></msub><mo>=</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mi>m</mi></mrow></mfrac><mrow><msub><mo stretchy="false">∑</mo><mrow><mi>s</mi></mrow></msub><mrow><msub><mrow><mi>P</mi></mrow><mrow><mi mathvariant="bold-italic">q</mi><mi mathvariant="bold-italic">s</mi></mrow></msub></mrow></mrow></math></td>
<td class="label">(5)</td>
</tr></table>
